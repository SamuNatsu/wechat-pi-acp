{
  "name": "wechat-pi-acp",
  "version": "1.0.0",
  "description": "WeChat-to-Pi ACP bridge — connect WeChat to Pi agent via QR login",
  "license": "MIT",
  "author": "SNRainiar",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamuNatsu/wechat-pi-acp"
  },
  "bugs": {
    "url": "https://github.com/SamuNatsu/wechat-pi-acp/issues"
  },
  "homepage": "https://github.com/SamuNatsu/wechat-pi-acp#readme",
  "keywords": [
    "wechat",
    "weixin",
    "acp",
    "agent-client-protocol",
    "pi-acp",
    "bridge",
    "qr-login"
  ],
  "type": "module",
  "bin": {
    "wechat-pi-acp": "./dist/cli.mjs"
  },
  "main": "./dist/cli.mjs",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.0",
    "cac": "^7.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=22"
  }
}
